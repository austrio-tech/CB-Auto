# === OpenRouter ===
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-REPLACE_WITH_YOUR_KEY

# Free-tier models (pick one):
#   meta-llama/llama-3.3-70b-instruct:free   ← recommended
#   deepseek/deepseek-v4-flash:free
#   qwen/qwen3-coder:free
#   nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# === API Security ===
# Any strong random string — client apps must send this as the X-API-Key header
API_KEY=REPLACE_WITH_A_STRONG_SECRET

# === Session ===
# How long (minutes) a ref_code stays valid before expiring
SESSION_TTL_MINUTES=30

# === Knowledge Base ===
# Folder containing your .md knowledge base files
KB_FOLDER=K_B

# === CORS ===
# Comma-separated origins allowed to call this API, or * for all
# Example: https://myapp.com,https://app2.com
ALLOWED_ORIGINS=*
